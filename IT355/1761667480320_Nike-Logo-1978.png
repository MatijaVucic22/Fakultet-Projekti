package com.example.fotolajk.controller;

import com.example.fotolajk.model.Category;
import com.example.fotolajk.model.Photo;
import com.example.fotolajk.service.PhotoService;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.file.StandardCopyOption;

@Controller
public class PhotoController {

    private final PhotoService photoService;

    public PhotoController(PhotoService photoService) {
        this.photoService = photoService;
    }

    @GetMapping("/")
    public String showGallery(Model model,
                              @ModelAttribute("msg") String flashMsg) {

        model.addAttribute("photos", photoService.findAll());

        if (flashMsg != null && !flashMsg.isBlank()) {
            model.addAttribute("msg", flashMsg);
        }

        return "gallery";
    }

    @GetMapping("/photo/add")
    public String showAddForm(Model model,
                              @ModelAttribute("msg") String flashMsg) {

        model.addAttribute("categories", Category.values());
        model.addAttribute("albums", photoService.getAllAlbums()); // NOVO

        if (flashMsg != null && !flashMsg.isBlank()) {
            model.addAttribute("msg", flashMsg);
        }

        return "add";
    }

    @PostMapping("/photo/save")
    public String savePhoto(
            @RequestParam String title,
            @RequestParam(required = false) String description,
            @RequestParam Category category,
            @RequestParam Long albumId, // NOVO
            @RequestParam("file") MultipartFile file,
            RedirectAttributes ra
    ) {
        try {
            String originalName = file.getOriginalFilename();
            if (originalName == null || originalName.isBlank()) {
                ra.addFlashAttribute("msg", "Greška: fajl nema ime.");
                return "redirect:/photo/add";
            }

            String fileName = System.currentTimeMillis() + "_" + originalName;

            Path uploadDir = Paths.get("target/classes/static/uploads");
            Files.createDirectories(uploadDir);

            Path destination = uploadDir.resolve(fileName);
            Files.copy(file.getInputStream(), destination, StandardCopyOption.REPLACE_EXISTING);

            String imageUrl = "/uploads/" + fileName;

            photoService.addNew(title, description, category, imageUrl, albumId);

            ra.addFlashAttribute("msg", "Fotografija sačuvana!");
            return "redirect:/";

        } catch (IOException e) {
            e.printStackTrace();
            ra.addFlashAttribute("msg", "Greška pri uploadu fajla.");
            return "redirect:/photo/add";
        }
    }

    @GetMapping("/photo/{id}")
    public String photoDetails(@PathVariable Long id, Model model) {
        Photo p = photoService.findById(id);
        if (p == null) {
            model.addAttribute("msg", "Fotografija nije pronađena.");
            return "details";
        }
        model.addAttribute("photo", p);
        return "details";
    }

    @GetMapping("/photo/delete/{id}")
    public String deletePhoto(@PathVariable Long id, RedirectAttributes ra) {
        boolean ok = photoService.deleteById(id);
        if (ok) {
            ra.addFlashAttribute("msg", "Fotografija obrisana.");
        } else {
            ra.addFlashAttribute("msg", "Fotografija nije pronađena.");
        }
        return "redirect:/";
    }

    @GetMapping("/photo/edit/{id}")
    public String editPhotoForm(@PathVariable Long id,
                                Model model,
                                @ModelAttribute("msg") String flashMsg) {

        Photo p = photoService.findById(id);
        if (p == null) {
            model.addAttribute("msg", "Fotografija nije pronađena.");
            return "edit";
        }

        model.addAttribute("photo", p);
        model.addAttribute("categories", Category.values());
        model.addAttribute("albums", photoService.getAllAlbums()); // NOVO

        if (flashMsg != null && !flashMsg.isBlank()) {
            model.addAttribute("msg", flashMsg);
        }

        return "edit";
    }

    @PostMapping("/photo/update")
    public String updatePhoto(
            @RequestParam Long id,
            @RequestParam String title,
            @RequestParam(required = false) String description,
            @RequestParam Category category,
            @RequestParam Long albumId, // NOVO
            @RequestParam(value = "file", required = false) MultipartFile file,
            RedirectAttributes ra
    ) {
        String newImageUrl = null;

        try {
            if (file != null && !file.isEmpty()) {
                String originalName = file.getOriginalFilename();
                String fileName = System.currentTimeMillis() + "_" + originalName;

                Path uploadDir = Paths.get("target/classes/static/uploads");
                Files.createDirectories(uploadDir);

                Path destination = uploadDir.resolve(fileName);
                Files.copy(file.getInputStream(), destination, StandardCopyOption.REPLACE_EXISTING);

                newImageUrl = "/uploads/" + fileName;
            }
        } catch (IOException e) {
            e.printStackTrace();
            ra.addFlashAttribute("msg", "Greška pri uploadu nove slike.");
            return "redirect:/photo/edit/" + id;
        }

        boolean ok = photoService.updatePhoto(id, title, description, category, newImageUrl, albumId);

        if (ok) {
            ra.addFlashAttribute("msg", "Fotografija ažurirana.");
        } else {
            ra.addFlashAttribute("msg", "Greška: fotografija nije pronađena.");
        }

        return "redirect:/";
    }
}
